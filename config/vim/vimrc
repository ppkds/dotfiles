" **** Functions ****
" == Optimize text telemetry calculations by running wordcount metrics only once
function! LightlineWordCount()
    let l:stats = wordcount()
    return printf('%d c : %d w', l:stats.chars, l:stats.words)
endfunction

" == Determine git branch
function! Lightlinegitbranch()
    let l:branch = FugitiveHead()
    return l:branch ==# '' ? '' : ' ' . l:branch
endfunction

" == Determine filesize - dynamically handles both base2 (IEC) and base10 (SI) scales
function! FileSize()
    let l:bytes = getfsize(expand("%:p"))
    if l:bytes <= 0
        return '0 B'
    endif

    " Select base system and labels dynamically based on user selection state
    if g:filesize_base2
        let l:scale = 1024.0
        let l:units = ['B', 'KiB', 'MiB', 'GiB', 'TiB', 'PiB']
    else
        let l:scale = 1000.0
        let l:units = ['B', 'kB', 'MB', 'GB', 'TB', 'PB']
    endif

    " Process unit metrics dynamically
    let l:size = str2float(l:bytes)
    let l:idx = 0
    while l:size >= l:scale && l:idx < len(l:units) - 1
        let l:size = l:size / l:scale
        let l:idx += 1
    endwhile

    return printf("%.2f %s", l:size, l:units[l:idx])
endfunction

