---- DEPENDENCIES & CLEANUP
sudo apt update
sudo apt install build-essential libncurses-dev libgtk-3-dev libatk1.0-dev libcairo2-dev libx11-dev libxpm-dev libxt-dev python3-dev ruby-dev lua5.2 liblua5.2-dev libperl-dev tcl-dev libcanberra-dev libacl1-dev git
sudo apt remove vim vim-runtime gvim vim-tiny vim-common vim-gui-common vim-nox

---- TO COMPILE FROM SCRATCH
make distclean

./configure --with-features=huge --enable-gui=gtk3 --enable-luainterp --enable-perlinterp --enable-python3interp=dynamic --enable-rubyinterp --enable-tclinterp --enable-cscope --with-compiledby="ppkds"

make
make test
sudo make install

---- EXECUTION FROM DOTFILES
eval "$(grep -E '^\./configure' $HOME/Dev/Git/dotfiles/config/vim/VIM_install)"

---- CHECK CHANGELOG & LIBRARIES
git log -p HEAD@{1}..HEAD
readelf -L /usr/local/bin/vim | grep Shared
