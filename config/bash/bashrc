# ~/.bashrc: executed by bash(1) for non-login shells.
# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return ;;
esac

# Default Editor
export EDITOR="vim"

# Dynamic spacing before prompt (prevents empty line on launch/clear)
add_prompt_space() {
    if [ -z "$FIRST_PROMPT" ]; then
        FIRST_PROMPT=1
    else
        echo ""
    fi
}

# Clear FIRST_PROMPT flag when 'clear' is run so top line stays flush
alias clear='FIRST_PROMPT= ; clear'

# History Configuration
HISTCONTROL=ignoreboth          # Ignore duplicates and leading spaces
HISTSIZE=200000                 # Session history size
HISTFILESIZE=200000             # File history size
PROMPT_COMMAND="add_prompt_space; history -a"  # Append history & handle spacing

# Directory & Navigation Options
shopt -s autocd                 # Type a folder path to cd into it
shopt -s cdspell 2>/dev/null    # Correct minor spelling errors on cd
shopt -s dirspell 2>/dev/null   # Correct minor spelling errors during completion
shopt -s cdable_vars            # Allow cd to variable names

# Folder Shortcuts
export desktopfolder="$HOME/Desktop"
export devfolder="$HOME/Dev"
export documentfolder="$HOME/Documents"
export dotfiles="$HOME/Dev/Git/dotfiles"
export downloadfolder="$HOME/Downloads"
export gitfolder="$HOME/Dev/Git"
export musicfolder="$HOME/Music"
export picturefolder="$HOME/Pictures"
export practicefolder="$HOME/Dev/Practice"
export publicfolder="$HOME/Public"
export rustprojects="$HOME/Dev/Rust/projects"
export templatefolder="$HOME/Templates"
export videofolder="$HOME/Videos"
export vimfolder="$HOME/Dev/Git/vim"

# General Shell Behavior
shopt -s checkwinsize           # Update terminal window size
shopt -s cmdhist                # Save multi-line commands as one command
shopt -s histverify             # Load history expansion onto line before running
shopt -s globstar               # Enable ** recursive globs

# Pager & Less Setup
export PAGER="less"
# shellcheck disable=SC1090
[[ -f ~/.LESS_TERMCAP ]] && . ~/.LESS_TERMCAP
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# Prompt Customization
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

case "$TERM" in
    xterm|xterm-color|*-256color) color_prompt=yes ;;
esac

if [ "$color_prompt" = yes ]; then
    if [[ ${EUID} == 0 ]]; then
        PS1='${debian_chroot:+($debian_chroot)}\[\033[01;31m\]┌── \h\[\033[01;34m\] \w\n\[\033[01;31m\]└─ \$\[\033[00m\] '
    else
        PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]┌── \h\[\033[01;34m\] \w\n\[\033[01;32m\]└─ \$\[\033[00m\] '
    fi
else
    PS1='${debian_chroot:+($debian_chroot)}\u@\h \w \$ '
fi
unset color_prompt force_color_prompt

# Colors & Aliases
if [ -x /usr/bin/dircolors ]; then
    if [ -r ~/.dircolors ]; then
        eval "$(dircolors -b ~/.dircolors)"
    else
        eval "$(dircolors -b)"
    fi
    alias dir='dir --color=auto'
    alias vdir='vdir --color=auto'
    alias grep='grep --color=auto'
    alias egrep='grep -E --color=auto'
    alias fgrep='grep -F --color=auto'
fi

export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# Alert alias for long running commands
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# Custom Aliases File
if [ -f "$HOME/.bashrc_aliases" ]; then
    # shellcheck disable=SC1090
    . "$HOME/.bashrc_aliases"
fi

# Bash Completion
if ! shopt -oq posix; then
    if [ -f /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    elif [ -f /etc/bash_completion ]; then
        . /etc/bash_completion
    fi
fi

# Toolchains / Environment Sourcing
# shellcheck disable=SC1091
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
# shellcheck disable=SC1091
[ -f "$HOME/.deno/env" ]  && . "$HOME/.deno/env"
