# ls aliases
alias ls='ls  --color=auto -ChFv --group-directories-first'         # more useful ls (list entries by columns + human readable + classify files + natural sort + group directories first)
    alias ll='ls -lhFv --group-directories-first'                   # ls (long listing format + human readable + classify files + natural sort + group directories first)
    alias lla='ls -alhFv --group-directories-first'                 # ls (include hidden files + long listing format + human readable + classify + natural sort + group directories first)
    alias lld='ls -alhFvd */'                                       # list directories only (include hidden files + long listing format + human readable + classify files + natural sort)

# exa aliases
    alias exa='exa -lhFv --group-directories-first'


# File and Directory aliases
    alias cp='cp -iv'
    alias mkdir='mkdir -pv'
    alias mv='mv -iv'
    alias rm='rm -Iv'

